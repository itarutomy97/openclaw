{
  "_comment": "Discord-only instance template (Alpha or Beta). Use OPENCLAW_STATE_DIR to isolate.",
  "browser": {
    "executablePath": "/snap/brave/600/opt/brave.com/brave/brave-browser",
    "headless": true,
    "noSandbox": true
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zai/glm-4.7"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": {
        "source": "env",
        "provider": "default",
        "id": "DISCORD_BOT_TOKEN"
      },
      "allowBots": true,
      "groupPolicy": "allowlist",
      "historyLimit": 20,
      "textChunkLimit": 2000,
      "streaming": "partial",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "guilds": {
        "YOUR_SERVER_ID": {
          "requireMention": false,
          "channels": {
            "YOUR_CHANNEL_ID": {
              "allow": true,
              "requireMention": false
            }
          }
        }
      }
    }
  },
  "gateway": {
    "port": 18791,
    "mode": "remote",
    "controlUi": {
      "allowedOrigins": ["https://openclaw.deskrex.ai"]
    },
    "auth": {
      "mode": "none"
    },
    "trustedProxies": [
      "127.0.0.1",
      "::1",
      "173.245.48.0/20",
      "103.21.244.0/22",
      "103.22.200.0/22",
      "103.31.4.0/22",
      "141.101.64.0/18",
      "108.162.192.0/18",
      "190.93.240.0/20",
      "188.114.96.0/20",
      "197.234.240.0/22",
      "198.41.128.0/17",
      "162.158.0.0/15",
      "104.16.0.0/13",
      "104.24.0.0/14",
      "172.64.0.0/13",
      "131.0.72.0/22"
    ]
  },
  "plugins": {
    "entries": {
      "discord": {
        "enabled": true
      },
      "camofox-browser": {
        "enabled": true
      }
    }
  }
}
