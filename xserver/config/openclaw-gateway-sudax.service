# OpenClaw Gateway Sudax systemd service template
# Discord bot instance (sudax, スダックス persona) on port 18800
# Variables to be replaced during restore:
#   {{NODE_PATH}} -> /root/.nvm/versions/node/v24.13.1/bin/node
#   {{OPENCLAW_PATH}} -> /root/.nvm/versions/node/v24.13.1/lib/node_modules/openclaw/dist/index.js

[Unit]
Description=OpenClaw Gateway Sudax (v2026.3.2)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart={{NODE_PATH}} {{OPENCLAW_PATH}} gateway --port 18800 --allow-unconfigured
Restart=always
RestartSec=5
KillMode=process
Environment=HOME=/root
Environment=OPENCLAW_STATE_DIR=/root/.openclaw-sudax
Environment=OPENCLAW_PROFILE=sudax
Environment=OPENCLAW_GATEWAY_PORT=18800
Environment="OPENCLAW_SYSTEMD_UNIT=openclaw-gateway-sudax.service"
Environment=OPENCLAW_SERVICE_MARKER=openclaw
Environment=OPENCLAW_SERVICE_KIND=gateway
Environment=OPENCLAW_SERVICE_VERSION=2026.3.2
Environment=ZAI_API_KEY={{ZAI_API_KEY}}
Environment=DISCORD_BOT_TOKEN_SUDAX={{DISCORD_BOT_TOKEN_SUDAX}}

[Install]
WantedBy=default.target
